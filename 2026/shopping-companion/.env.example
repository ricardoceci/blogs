# AWS — needs bedrock:InvokeModel permission
AWS_DEFAULT_REGION=us-east-1
# AWS_ACCESS_KEY_ID=...        # Only if not using IAM role / AWS SSO
# AWS_SECRET_ACCESS_KEY=...

# Bedrock model
BEDROCK_MODEL_ID=anthropic.claude-sonnet-4-20250514-v1:0

# ── Product backend ──────────────────────────────────────────────────────────
# shopify  → live Shopify Storefront MCP (recommended, no auth needed)
# local    → local JSON catalog + BM25 (for testing without a Shopify store)
PRODUCT_BACKEND=shopify

# Shopify store domain — required when PRODUCT_BACKEND=shopify
# Format: your-store.myshopify.com (no https://)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Local catalog path — only used when PRODUCT_BACKEND=local
CATALOG_PATH=data/products.json

# ── Mem0 memory ──────────────────────────────────────────────────────────────
# Managed cloud (free tier at mem0.ai)
MEM0_API_KEY=your-mem0-api-key

# Models used internally by the mem0_memory tool (Bedrock)
MEM0_LLM_MODEL=anthropic.claude-3-5-haiku-20241022-v1:0
MEM0_EMBEDDER_MODEL=amazon.titan-embed-text-v2:0

# Set to "true" to use local FAISS instead of Mem0 cloud
USE_LOCAL_MEMORY=false
LOCAL_MEMORY_PATH=./data/local_memories
